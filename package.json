{
  "name": "youtrack-issue",
  "version": "0.1.0",
  "description": "Standalone CLI for fetching YouTrack issues by ID",
  "private": true,
  "type": "module",
  "files": [
    "bin",
    "README.md"
  ],
  "bin": {
    "youtrack-issue": "./bin/ytissue.mjs",
    "ytissue": "./bin/ytissue.mjs"
  },
  "scripts": {
    "youtrack-issue": "node ./bin/ytissue.mjs",
    "check": "node --check ./bin/ytissue.mjs",
    "test": "vitest run",
    "test:verbose": "vitest run --reporter=verbose",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
